# ================================
# 必需配置 - 请替换为您的实际密钥
# ================================

# 建议在正式部署时启用 prod profile
SPRING_PROFILES_ACTIVE=prod

# 阿里云百炼 AI (DashScope) - LLM + ASR + TTS 服务
AI_BAILIAN_API_KEY=your_dashscope_api_key_here

# 首次启动默认管理员账号（首次部署时请显式设置，不要使用弱口令）
APP_AUTH_BOOTSTRAP_EMAIL=admin@example.com
APP_AUTH_BOOTSTRAP_PASSWORD=change_me_to_a_strong_password
APP_AUTH_BOOTSTRAP_NAME=Administrator

# ================================
# 可选配置 - 与根目录 docker-compose.yml 对齐（本地 bootRun 连 compose 起的依赖时勿改）
# ================================

# PostgreSQL（compose 默认：库 interview_guide / 用户 postgres / 密码 password / 映射端口 5432）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=interview_guide
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Redis（compose 映射 6379）
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / S3 兼容存储（compose：MINIO_ROOT_USER/PASSWORD=minioadmin，API 映射 9000）
APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=minioadmin
APP_STORAGE_SECRET_KEY=minioadmin
APP_STORAGE_BUCKET=interview-guide
APP_STORAGE_REGION=us-east-1

# AI 模型配置 (默认: qwen-plus)
AI_MODEL=qwen-plus

# 正式部署时请替换为你的实际前端域名，多个域名使用逗号分隔
CORS_ALLOWED_ORIGINS=https://your-domain.example

# 语音面试（可选）：多段 STT 合并后再触发面试官；ASR 句间静音阈值（越大越不易句中切开）
# APP_VOICE_USER_UTTERANCE_DEBOUNCE_MS=1600
# APP_VOICE_ASR_SILENCE_MS=1000

# ================================
# 可选：其他 AI 服务提供商
# ================================

# MiniMax (如果使用 MiniMax 替代 DashScope)
# APP_VOICE_INTERVIEW_LLM_PROVIDER=minimax
# MINIMAX_API_KEY=your_minimax_api_key
# MINIMAX_GROUP_ID=your_minimax_group_id

# OpenAI (如果使用 OpenAI)
# APP_VOICE_INTERVIEW_LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key

# DeepSeek (如果使用 DeepSeek)
# APP_VOICE_INTERVIEW_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your_deepseek_api_key
